# ── Tracely environment (copy to .env) ─────────────────────────────────────────
TRACELY_ENV=dev

# Postgres (registry) — async driver for the app, sync for Alembic
DATABASE_URL=postgresql+asyncpg://tracely:tracely@localhost:5432/tracely
ALEMBIC_DATABASE_URL=postgresql+psycopg://tracely:tracely@localhost:5432/tracely

# ClickHouse (events + scores)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=tracely

# Redis (Celery broker + result backend)
REDIS_URL=redis://localhost:6379/0

# S3 / MinIO (raw OTLP blob = source of truth)
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=tracely
S3_SECRET_ACCESS_KEY=tracely-secret
S3_BUCKET=tracely-events
S3_EVENT_PREFIX=events/

# Ingestion tuning
CLICKHOUSE_ASYNC_INSERT=1            # rely on CH server-side batching (Celery has no shared in-proc buffer)
INGESTION_DELAY_SECONDS=0            # OTLP path: no artificial delay (mirrors Langfuse getDelay otel branch)

# ── Auth & multi-tenancy ───────────────────────────────────────────────────────
# dev   = no human login; the ingest key is the only credential (default, unchanged behavior).
# local = self-host email/password (Railway). Requires SESSION_SECRET. First user = OWNER, then invite-only.
# clerk = hosted SaaS; Clerk owns login/orgs. Requires CLERK_ISSUER (+ frontend Clerk keys).
AUTH_MODE=dev
# Required when AUTH_MODE=local — sign the session JWT. Generate: openssl rand -hex 32
SESSION_SECRET=
SESSION_TTL_SECONDS=604800          # 7 days
SESSION_ISSUER=tracely
# Required when AUTH_MODE=clerk (e.g. https://your-app.clerk.accounts.dev)
CLERK_ISSUER=
# CLERK_JWKS_URL=                    # optional; derived from CLERK_ISSUER when blank
# CLERK_AUDIENCE=                    # optional 'aud' to pin
# CLERK_SECRET_KEY=                  # optional, for Clerk Backend API calls
# FRONTEND_ORIGIN=https://app.example.com   # hosted only: allow direct browser calls (CORS)

# ── Transactional email (Resend) — optional ────────────────────────────────────
# When set, team invites are emailed automatically; when blank, the invite link is shown once in the
# UI for manual sharing (no email sent). Create a key at https://resend.com.
# RESEND_API_KEY=
# Sender identity. The default (onboarding@resend.dev) only delivers to your own Resend-account
# email — verify a domain at resend.com/domains to email real teammates.
# EMAIL_FROM=Tracely <onboarding@resend.dev>
# Public URL of the frontend, used to build the accept-invite link in invite emails.
# APP_BASE_URL=http://localhost:3001
