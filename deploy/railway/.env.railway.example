# ─────────────────────────────────────────────────────────────────────────────
# Tracely on Railway — variable reference (copy values into each service's Variables tab).
# Reference syntax ${{ServiceName.VAR}} links to another service; service names below assume the
# default template names: Postgres (pgvector), Redis, ClickHouse, MinIO, backend, worker, frontend.
# Verify each source variable name in that plugin's own Variables tab — template versions differ.
# ─────────────────────────────────────────────────────────────────────────────

# ===== SHARED by backend + worker =====
# Set these as Project → Shared Variables and reference ${{shared.NAME}} from both services,
# OR just paste them into both the `backend` and `worker` services.

TRACELY_ENV=railway

# Postgres (pgvector template). Construct both driver URLs from the template's parts (we can't prefix
# the template's own DATABASE_URL with a driver). pgvector listens on 5432.
DATABASE_URL=postgresql+asyncpg://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.RAILWAY_PRIVATE_DOMAIN}}:5432/${{Postgres.PGDATABASE}}
ALEMBIC_DATABASE_URL=postgresql+psycopg://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.RAILWAY_PRIVATE_DOMAIN}}:5432/${{Postgres.PGDATABASE}}

# ClickHouse template (HTTP interface on 8123, private). The migrate step creates the `tracely` DB.
CLICKHOUSE_HOST=${{ClickHouse.RAILWAY_PRIVATE_DOMAIN}}
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=${{ClickHouse.CLICKHOUSE_USER}}
CLICKHOUSE_PASSWORD=${{ClickHouse.CLICKHOUSE_PASSWORD}}
CLICKHOUSE_DATABASE=tracely
CLICKHOUSE_ASYNC_INSERT=1

# Redis template. Prefer the private URL; if the template only exposes REDIS_URL as a public proxy,
# construct the private one: redis://default:${{Redis.REDIS_PASSWORD}}@${{Redis.RAILWAY_PRIVATE_DOMAIN}}:6379
REDIS_URL=${{Redis.REDIS_PRIVATE_URL}}

# MinIO template (S3 API on 9000, private). The backend pre-deploy step auto-creates the bucket.
S3_ENDPOINT_URL=http://${{MinIO.RAILWAY_PRIVATE_DOMAIN}}:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=${{MinIO.MINIO_ROOT_USER}}
S3_SECRET_ACCESS_KEY=${{MinIO.MINIO_ROOT_PASSWORD}}
S3_BUCKET=tracely-events
S3_EVENT_PREFIX=events/

# Auth: self-host => local (email/password). SaaS => clerk.
AUTH_MODE=local
# REQUIRED for AUTH_MODE=local. Generate: openssl rand -hex 32  (Railway can also generate a secret)
SESSION_SECRET=
SESSION_TTL_SECONDS=604800
# AUTH_MODE=clerk only:
# CLERK_ISSUER=https://your-app.clerk.accounts.dev
# CLERK_SECRET_KEY=sk_...
# FRONTEND_ORIGIN=https://${{frontend.RAILWAY_PUBLIC_DOMAIN}}

# Optional — failure-intelligence embeddings/agents + LLM-judge evaluator (skipped if unset)
# OPENAI_API_KEY=sk-...
# LLM_JUDGE_API_KEY=${{ OPENAI_API_KEY }}


# ===== backend service ONLY =====
# Fixed port so the frontend can reach the backend privately at a known port.
PORT=8000


# ===== frontend service ONLY =====
PORT=3000
# Server-side fetches reach the backend over the private network (no egress cost).
TRACELY_API=http://${{backend.RAILWAY_PRIVATE_DOMAIN}}:${{backend.PORT}}
# Must MATCH the backend AUTH_MODE. Also add it as a *Build* variable (it's inlined into the client
# bundle at `next build` — see the Dockerfile.railway ARGs).
NEXT_PUBLIC_AUTH_MODE=local
# AUTH_MODE=clerk only (set NEXT_PUBLIC_* ones as Build variables too):
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
# CLERK_SECRET_KEY=sk_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
